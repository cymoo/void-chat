# ============================================================
#  void-chat — environment variables
#
#  Copy this file to .env and fill in your values.
#  docker compose automatically loads .env from this directory.
# ============================================================

# ---- Domain (required for HTTPS / make setup) ----
DOMAIN=example.com

# ---- Database ----
DB_USER=postgres
DB_PASSWORD=change-me

# ---- Initial admin (created/promoted on first startup) ----
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=change-me

# ---- Simple HTTP deployment only (ignored by make setup/deploy) ----
# Host port that the frontend nginx container listens on
HTTP_PORT=80

# ---- Session ----
SESSION_TTL_DAYS=7

# ---- LLM Persona engine (optional — leave blank to disable) ----
PERSONA_LLM_API_KEY=
PERSONA_LLM_BASE_URL=
PERSONA_LLM_MODEL=
PERSONA_AUTO_ENGAGE=false
