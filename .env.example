# ============================================================
#  void-chat — Docker Compose environment variables
#
#  Copy this file to .env and adjust values for your setup.
#  docker compose automatically loads .env from the same directory.
# ============================================================

# ---- Database ----
DB_USER=postgres
DB_PASSWORD=postgres

# ---- Web ----
# Host port that the frontend (nginx) listens on
HTTP_PORT=80

# ---- Initial admin (created/promoted on first startup) ----
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=changeme

# ---- Session ----
SESSION_TTL_DAYS=7

# ---- LLM Persona engine (optional — leave blank to disable) ----
PERSONA_LLM_API_KEY=
PERSONA_LLM_BASE_URL=
PERSONA_LLM_MODEL=
PERSONA_AUTO_ENGAGE=false
