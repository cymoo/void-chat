# ============================================================
#  void-chat backend environment configuration
#
#  Copy this file to .env and adjust values for your environment.
#  Load order: .env → .env.{COLLEEN_ENV} → .env.local
#  Priority:   System env > System properties > .env files
# ============================================================

# Active profile: dev | prod | test
COLLEEN_ENV=prod

# ---- Database (PostgreSQL) ----
DATABASE_URL=jdbc:postgresql://localhost:5432/void_chat
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Server ----
SERVER_PORT=8000
MAX_REQUEST_SIZE=31457280          # 30 MB

# ---- File uploads ----
UPLOAD_DIR=../uploads
MAX_IMAGE_SIZE=5242880             # 5 MB
MAX_FILE_SIZE=20971520             # 20 MB

# ---- WebSocket ----
WS_IDLE_TIMEOUT_MS=600000         # 10 minutes
WS_MAX_MESSAGE_SIZE=262144        # 256 KB
WS_PING_INTERVAL_MS=30000         # 30 seconds
WS_PING_TIMEOUT_MS=10000          # 10 seconds
WS_MAX_CONNECTIONS=500

# ---- Session ----
SESSION_TTL_DAYS=7

# ---- Initial admin (optional) ----
# Set both to create/promote a super_admin on startup.
# INIT_ADMIN_USERNAME=admin
# INIT_ADMIN_PASSWORD=changeme
